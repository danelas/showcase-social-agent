# Google Gemini API key with billing enabled (Veo is paid-tier only).
# Get one at https://aistudio.google.com/apikey  then enable billing in Google Cloud.
GEMINI_API_KEY=

# Which Veo model to use. Run `node -e` ListModels if unsure what your key has.
#   veo-3.1-generate-preview        (standard)
#   veo-3.1-fast-generate-preview   (faster + cheaper — good default)
#   veo-3.1-lite-generate-preview   (cheapest)
VEO_MODEL=veo-3.1-fast-generate-preview

# Set MOCK=1 to skip Veo entirely and preview the Remotion overlays for free
# (scenes render over a branded gradient instead of real footage).
MOCK=0
