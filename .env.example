# ── Shared PeekScout Postgres (Supabase) ──
# Same database the PeekScout app uses. Grab both from the app's Vercel env.
POSTGRES_PRISMA_URL="postgres://...pooler.supabase.com:6543/postgres?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://...supabase.com:5432/postgres"

# ── Google Places (API New must be enabled on the project) ──
GOOGLE_MAPS_API_KEY=""
# GOOGLE_PLACES_API_KEY=""   # optional: separate key

# ── Resend (cold email) ──
RESEND_API_KEY=""            # re_…
RESEND_FROM_EMAIL=""         # "Dan <dan@yourdomain.com>" — domain verified in Resend

# ── App ──
NEXT_PUBLIC_APP_URL="https://your-showcase-domain.com"   # used to build /claim/<token> links
# RECRUIT_BRAND="PeekScout"   # optional: public name used in the email copy
